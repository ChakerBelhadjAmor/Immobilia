# Copy to .env before running `docker compose up`.
# Defaults below are dev-only. Never reuse them outside local development.

# ---- App ----
ENVIRONMENT=development
API_PORT=8000

# ---- PostgreSQL ----
POSTGRES_USER=immobilia
POSTGRES_PASSWORD=immobilia
POSTGRES_DB=immobilia
# Host is the compose service name when running inside Docker
DATABASE_URL=postgresql+asyncpg://immobilia:immobilia@postgres:5432/immobilia

# ---- Qdrant ----
QDRANT_URL=http://qdrant:6333

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- MinIO ----
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_SECURE=false

# ---- Auth ----
# Generate your own: openssl rand -hex 32
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
SESSION_TTL_SECONDS=604800

# ---- Mistral ----
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
